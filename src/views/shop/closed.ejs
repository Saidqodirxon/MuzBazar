<%- include('partials/header') %>
<div style="display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 60vh; text-align: center; padding: 2rem;">
    <div style="font-size: 5rem; margin-bottom: 20px; color: var(--danger); opacity: 0.8;">
        <i class="fas fa-store-slash"></i>
    </div>
    
    <h1 style="font-size: 1.8rem; font-weight: 800; margin-bottom: 1rem; color: var(--text);">
        Do'kon yopiq
    </h1>
    
    <div class="card" style="padding: 2rem; border-radius: 20px; max-width: 400px; background: white; box-shadow: 0 10px 25px rgba(0,0,0,0.05);">
        <p style="font-size: 1.1rem; line-height: 1.6; color: var(--text-muted); white-space: pre-line;">
            <%= message %>
        </p>
    </div>
    
    <a href="/shop" class="btn btn-primary" style="margin-top: 2rem; padding: 12px 30px; border-radius: 50px;">
        <i class="fas fa-sync-alt"></i> Sahifani yangilash
    </a>
</div>
<%- include('partials/footer') %>
