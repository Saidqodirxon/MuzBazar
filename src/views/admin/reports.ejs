<% 
const layout='../layouts/layout.ejs'; 
function fmt(n) { 
    return (n || 0).toLocaleString('ru-RU').replace(/,/g, ' '); 
} 

const isAdmin = locals.admin && locals.admin.role === 'admin';
let sRows = ''; 

if (typeof stats !== 'undefined' && stats.sellerStats && stats.sellerStats.length > 0) {
    stats.sellerStats.forEach((s, idx) => {
        const bClass = (s.balance || 0) > 0 ? 'text-danger' : 'text-success';
        sRows += `
        <tr>
            <td><strong>${s.name || ''}</strong></td>
            <td>${fmt(s.todayOrders)} ta</td>
            <td>${fmt(s.todaySales)} soʻm</td>
            <td>${fmt(s.todayRevenue)} soʻm</td>
            ${isAdmin ? `<td><span class="text-info">${fmt(s.todayProfit)} soʻm</span></td>` : ''}
            <td><span class="fw-bold ${bClass}">${fmt(s.balance)} soʻm</span></td>
        </tr>`;
    });
} else {
    sRows = `<tr><td colspan="${isAdmin ? 6 : 5}" class="text-center py-4 text-muted">Maʻlumot yoʻq</td></tr>`;
}

let todayStats = `
<div class="row mb-4">
    <!-- Today's Profit -->
    <div class="col-md-3 mb-3">
        <div class="card bg-info text-white h-100 shadow-sm border-0 border-start border-white border-5">
            <div class="card-body py-3">
                <div class="small text-uppercase opacity-75">Bugungi Foyda</div>
                <div class="h4 mb-0 fw-bold">${fmt(stats.todayProfit)} <small class="fw-normal" style="font-size: 0.6em">soʻm</small></div>
            </div>
        </div>
    </div>
    <!-- Today's Sales -->
    <div class="col-md-3 mb-3">
        <div class="card bg-primary text-white h-100 shadow-sm border-0 border-start border-white border-5">
            <div class="card-body py-3">
                <div class="small text-uppercase opacity-75">Bugungi Savdo</div>
                <div class="h4 mb-0 fw-bold">${fmt(stats.todaySales)} <small class="fw-normal" style="font-size: 0.6em">soʻm</small></div>
            </div>
        </div>
    </div>
    <!-- Today's Revenue -->
    <div class="col-md-3 mb-3">
        <div class="card bg-success text-white h-100 shadow-sm border-0 border-start border-white border-5">
            <div class="card-body py-3">
                <div class="small text-uppercase opacity-75">Bugungi Kirim</div>
                <div class="h4 mb-0 fw-bold">${fmt(stats.todayRevenue)} <small class="fw-normal" style="font-size: 0.6em">soʻm</small></div>
            </div>
        </div>
    </div>
    <!-- Today's Orders -->
    <div class="col-md-3 mb-3">
        <div class="card bg-warning text-dark h-100 shadow-sm border-0 border-start border-dark border-5">
            <div class="card-body py-3">
                <div class="small text-uppercase opacity-75">Bugungi Buyurtmalar</div>
                <div class="h4 mb-0 fw-bold">${fmt(stats.todayOrders)} <small class="fw-normal" style="font-size: 0.6em">ta</small></div>
            </div>
        </div>
    </div>
</div>`;

let bodyPrefix = `
<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pb-2 mb-3 border-bottom">
    <h1 class="h2"><i class="fas fa-chart-line me-2"></i>Hisobotlar</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <a href="/admin/reports/export" class="btn btn-sm btn-outline-secondary"><i class="fas fa-download me-1"></i>Export</a>
    </div>
</div>

<div class="position-relative">
    ${todayStats}
    <!-- Small subtle toggle -->
    <div style="position: absolute; bottom: -10px; right: 10px; opacity: 0.3;">
        <a href="javascript:void(0)" class="text-muted" data-bs-toggle="collapse" data-bs-target="#extraRepStats" style="font-size: 10px; text-decoration: none;">
            <i class="fas fa-plus"></i>
        </a>
    </div>
</div>
`;

let bodyMiddle = `
<div class="collapse" id="extraRepStats">
    <div class="row mb-4">
        <!-- Total Debt -->
        <div class="col-md-4 mb-3">
            <div class="card bg-danger text-white h-100 shadow-sm border-0">
                <div class="card-body">
                    <div class="small text-uppercase opacity-75">Umumiy Qarz</div>
                    <div class="h3 mb-0 fw-bold">${fmt(stats.totalDebt)} <small class="fw-normal" style="font-size: 0.6em">soʻm</small></div>
                </div>
            </div>
        </div>
        <!-- Total Customers -->
        <div class="col-md-4 mb-3">
            <div class="card bg-secondary text-white h-100 shadow-sm border-0">
                <div class="card-body">
                    <div class="small text-uppercase opacity-75">Barcha Mijozlar</div>
                    <div class="h3 mb-0 fw-bold">${fmt(stats.totalCustomers)}</div>
                </div>
            </div>
        </div>
        <!-- Monthly Revenue -->
        <div class="col-md-4 mb-3">
            <div class="card bg-light border h-100 shadow-sm">
                <div class="card-body">
                    <div class="small text-uppercase text-muted">Shu oygi savdo</div>
                    <div class="h3 mb-0 fw-bold text-dark">${fmt(stats.monthlyRevenue)} soʻm</div>
                </div>
            </div>
        </div>
    </div>
    
    ${isAdmin ? `
    <div class="row mb-4">
        <div class="col-md-6 mb-3">
            <div class="card h-100 border-0 shadow-sm border-start border-success border-4">
                <div class="card-body">
                    <h6 class="text-muted text-uppercase small fw-bold mb-0">Jami Foyda (Barcha)</h6>
                    <div class="h4 mb-0 fw-bold text-success">${fmt(stats.totalProfit)} soʻm</div>
                </div>
            </div>
        </div>
        <div class="col-md-6 mb-3">
            <div class="card h-100 border-0 shadow-sm border-start border-primary border-4">
                <div class="card-body">
                    <h6 class="text-muted text-uppercase small fw-bold mb-0">Jami Buyurtmalar</h6>
                    <div class="h4 mb-0 fw-bold text-primary">${fmt(stats.totalOrders)} ta</div>
                </div>
            </div>
        </div>
    </div>` : ''}
</div>`;

let bodyFooter = `
<div class="card shadow-sm border-0">
    <div class="card-header bg-white py-3">
        <h5 class="mb-0"><i class="fas fa-users-cog me-2 text-primary"></i>Sotuvchilar boʻyicha hisobot (Bugun)</h5>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-striped mb-0">
                <thead class="table-dark">
                    <tr><th>Sotuvchi</th><th>Buyurtmalar</th><th>Savdo</th><th>Kirim</th>${isAdmin ? '<th>Foyda</th>' : ''}<th>Balans</th></tr>
                </thead>
                <tbody>${sRows}</tbody>
            </table>
        </div>
    </div>
</div>
`;

const body = bodyPrefix + bodyMiddle + bodyFooter;
%>
<%- include(layout, { body: body, title: title }) %>