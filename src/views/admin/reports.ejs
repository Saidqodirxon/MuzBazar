<% const layout="../layouts/layout.ejs" ; function fmt(n) { return (n || 0).toLocaleString("ru-RU"); } let sRows="" ; if
    (typeof stats !=="undefined" && stats.sellerStats && stats.sellerStats.length> 0) {
    for (let i = 0; i < stats.sellerStats.length; i++) { let s=stats.sellerStats[i]; sRows +="<tr>" + "<td><strong>" +
        (s.name || "" ) + "</strong></td>" + "<td>" + fmt(s.todaySales) + "</td>" + "<td>" + fmt(s.todayRevenue)
        + "</td>" + "<td>" + fmt(s.balance) + "</td>" + "</tr>" ; } } else {
        sRows="<tr><td colspan='4'>Ma'lumot yo'q</td></tr>" ; } const body="<div>" + "<h1>Hisobotlar</h1>"
        + "<table class='table'><thead><tr><th>Sotuvchi</th><th>Savdo</th><th>Kirim</th><th>Qoldiq</th></tr></thead>"
        + "<tbody>" + sRows + "</tbody>" + "</table>" + "</div>" ; %>
        <%- include(layout, { body: body, title: "Hisobotlar" }) %>