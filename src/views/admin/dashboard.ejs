<%
var layout = '../layouts/layout.ejs';

function fmt(n) {
    var s = String(n || 0);
    var parts = [];
    var len = s.length;
    for (var i = len; i > 0; i -= 3) {
        var start = Math.max(0, i - 3);
        parts.unshift(s.substring(start, i));
    }
    return parts.join(' ');
}

var isAdmin = locals.admin && locals.admin.role === 'admin';

var lowStockHtml = '';
if (!lowStockProducts || lowStockProducts.length === 0) {
    lowStockHtml = '<p class="text-muted">Barcha mahsulotlar yetarli miqdorda mavjud</p>';
} else {
    lowStockHtml = '<div class="list-group">';
    for (var i = 0; i < lowStockProducts.length; i++) {
        var product = lowStockProducts[i];
        lowStockHtml += `
        <div class="list-group-item d-flex justify-content-between align-items-center">
            <div><strong>${product.name}</strong><br><small class="text-muted">Minimal: ${product.minStock}</small></div>
            <span class="badge bg-warning rounded-pill">${product.stock} qoldi</span>
        </div>`;
    }
    lowStockHtml += '</div>';
}

var ordersHtml = '';
if (!recentOrders || recentOrders.length === 0) {
    ordersHtml = '<p class="text-muted">Hali buyurtmalar yoʻq</p>';
} else {
    var ordersRows = recentOrders.map(order => {
        var statusClass = 'secondary';
        var statusText = order.status || '';
        if (order.status === 'pending') { statusClass = 'warning'; statusText = 'Kutilmoqda'; }
        else if (order.status === 'confirmed') { statusClass = 'info'; statusText = 'Tasdiqlangan'; }
        else if (order.status === 'delivered') { statusClass = 'success'; statusText = 'Yetkazilgan'; }
        else if (order.status === 'cancelled') { statusClass = 'danger'; statusText = 'Bekor qilingan'; }

        var debt = order.debt || 0;
        var debtColor = debt > 0 ? 'text-danger' : 'text-success';
        var clientName = order.client ? `${order.client.firstName || ''} ${order.client.lastName || ''}` : 'Nomaʻlum';
        var orderDate = moment(order.createdAt).utcOffset(5).format('DD/MM/YYYY HH:mm');

        return `
        <tr>
            <td><strong>${order.orderNumber || ''}</strong></td>
            <td>${clientName}</td>
            <td>${fmt(order.totalSum)} soʻm</td>
            <td class="text-success">${fmt(order.totalPaid)} soʻm</td>
            <td class="${debtColor}"><strong>${fmt(debt)} soʻm</strong></td>
            <td><span class="badge bg-${statusClass}">${statusText}</span></td>
            <td>${orderDate}</td>
            <td><a href="/admin/orders/${order._id}" class="btn btn-sm btn-outline-primary"><i class="fas fa-eye"></i></a></td>
        </tr>`;
    }).join('');

    ordersHtml = `
    <div class="table-responsive">
        <table class="table table-hover">
            <thead class="table-light">
                <tr><th>Buyurtma</th><th>Klient</th><th>Summa</th><th>Toʻlangan</th><th>Qoldiq</th><th>Status</th><th>Sana</th><th>Amallar</th></tr>
            </thead>
            <tbody>${ordersRows}</tbody>
        </table>
    </div>`;
}

let todayStats = `
<div class="row mb-4">
    <!-- Today's Profit -->
    ${isAdmin ? `
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-0 border-start border-info border-5 shadow-sm h-100 py-2">
            <div class="card-body">
                <div class="text-xs font-weight-bold text-info text-uppercase mb-1">Bugungi foyda</div>
                <div class="h5 mb-0 font-weight-bold text-gray-800">${fmt(stats.todayProfit)} soʻm</div>
            </div>
        </div>
    </div>` : ''}

    <!-- Today's Sales -->
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-0 border-start border-primary border-5 shadow-sm h-100 py-2">
            <div class="card-body">
                <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Bugungi savdo</div>
                <div class="h5 mb-0 font-weight-bold text-gray-800">${fmt(stats.todaySales)} soʻm</div>
            </div>
        </div>
    </div>

    <!-- Today's Revenue -->
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-0 border-start border-success border-5 shadow-sm h-100 py-2">
            <div class="card-body">
                <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Bugungi toʻlovlar</div>
                <div class="h5 mb-0 font-weight-bold text-gray-800">${fmt(stats.todayRevenue)} soʻm</div>
            </div>
        </div>
    </div>

    <!-- Today's Orders -->
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-0 border-start border-warning border-5 shadow-sm h-100 py-2">
            <div class="card-body">
                <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">Bugungi buyurtmalar</div>
                <div class="h5 mb-0 font-weight-bold text-gray-800">${stats.todayOrders || 0} ta</div>
            </div>
        </div>
    </div>
</div>`;

let bodyPrefix = `
<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pb-2 mb-3 border-bottom">
    <h1 class="h2"><i class="fas fa-tachometer-alt me-2"></i>Dashboard</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <div class="btn-group me-2">
            <a href="/admin/reports/export" class="btn btn-sm btn-outline-secondary"><i class="fas fa-download me-1"></i>Export</a>
        </div>
    </div>
</div>

<div class="position-relative">
    ${todayStats}
    <!-- Small subtle toggle -->
    <div style="position: absolute; bottom: -10px; right: 10px; opacity: 0.3;">
        <a href="javascript:void(0)" class="text-muted" data-bs-toggle="collapse" data-bs-target="#extraStats" style="font-size: 10px; text-decoration: none;">
            <i class="fas fa-plus"></i>
        </a>
    </div>
</div>
`;

let bodyMiddle = `
<div class="collapse" id="extraStats">
    <div class="row mb-4">
        <div class="col-xl-4 col-md-6 mb-4">
            <div class="card border-0 border-start border-secondary border-5 shadow-sm h-100 py-2">
                <div class="card-body">
                    <div class="text-xs font-weight-bold text-secondary text-uppercase mb-1">Mahsulotlar</div>
                    <div class="h5 mb-0 font-weight-bold text-gray-800">${stats.totalProducts} ta</div>
                </div>
            </div>
        </div>
        <div class="col-xl-4 col-md-6 mb-4">
            <div class="card border-0 border-start border-secondary border-5 shadow-sm h-100 py-2">
                <div class="card-body">
                    <div class="text-xs font-weight-bold text-secondary text-uppercase mb-1">Barcha buyurtmalar</div>
                    <div class="h5 mb-0 font-weight-bold text-gray-800">${stats.totalOrders} ta</div>
                </div>
            </div>
        </div>
        <div class="col-xl-4 col-md-6 mb-4">
            <div class="card border-0 border-start border-danger border-5 shadow-sm h-100 py-2">
                <div class="card-body">
                    <div class="text-xs font-weight-bold text-danger text-uppercase mb-1">Umumiy qarzdorlik</div>
                    <div class="h5 mb-0 font-weight-bold text-gray-800">${fmt(stats.totalDebt)} soʻm</div>
                </div>
            </div>
        </div>
    </div>
</div>
`;

let lowStockCard = '';
if (isAdmin) {
    lowStockCard = `
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-white"><h5><i class="fas fa-exclamation-triangle me-2 text-warning"></i>Kam qolgan mahsulotlar</h5></div>
            <div class="card-body">${lowStockHtml}</div>
        </div>
    </div>`;
}

let bodyFooter = `
<div class="row mb-4">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-white"><h5><i class="fas fa-plus-circle me-2 text-primary"></i>Tezkor harakatlar</h5></div>
            <div class="card-body"><div class="d-grid gap-2">
                <a href="/admin/products/new" class="btn btn-primary"><i class="fas fa-plus me-2"></i>Yangi mahsulot</a>
                <a href="/admin/categories/new" class="btn btn-outline-primary"><i class="fas fa-tags me-2"></i>Yangi kategoriya</a>
                <a href="/admin/debts" class="btn btn-outline-warning"><i class="fas fa-money-bill-wave me-2"></i>Qarzdorlik boshqaruvi</a>
            </div></div>
        </div>
    </div>
    ${lowStockCard}
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="fas fa-clock me-2 text-primary"></i>Soʻnggi buyurtmalar</h5>
        <a href="/admin/orders" class="btn btn-sm btn-outline-primary">Barchasini koʻrish</a>
    </div>
    <div class="card-body p-0">${ordersHtml}</div>
</div>
`;

const body = bodyPrefix + bodyMiddle + bodyFooter;
%>
<%- include(layout, { body: body, title: title }) %>
