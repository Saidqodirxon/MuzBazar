<%
const layout = '../layouts/layout.ejs';

const body = `
<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pb-2 mb-3 border-bottom">
    <h1 class="h2">
        <i class="fas fa-cogs me-2"></i>Sozlamalar
    </h1>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header">
                <h5><i class="fas fa-sliders-h me-2"></i>Asosiy sozlamalar</h5>
            </div>
            <div class="card-body">
                <form method="POST" action="/admin/settings">
                    ${allSettings.map(setting => {
                        const value = settings[setting.key] !== undefined ? settings[setting.key] : setting.defaultValue;

                        if (setting.type === 'boolean') {
                            const isShopStatus = setting.key === 'shop_is_open';
                            return `
                            <div class="mb-3 p-3 border rounded ${isShopStatus ? (value ? 'border-success bg-success bg-opacity-10' : 'border-danger bg-danger bg-opacity-10') : ''}">
                                <div class="form-check form-switch d-flex align-items-center gap-3">
                                    <input type="checkbox" class="form-check-input" role="switch" id="${setting.key}" name="${setting.key}" ${value ? 'checked' : ''} style="width:3em;height:1.5em;cursor:pointer;" ${isShopStatus ? 'onchange="updateShopStatusStyle(this)"' : ''}>
                                    <div>
                                        <label class="form-check-label mb-0" for="${setting.key}">
                                            <strong>${setting.label || setting.key}</strong>
                                            ${isShopStatus ? '<span id="shop_status_badge" class="badge ms-2 ' + (value ? 'bg-success' : 'bg-danger') + '">' + (value ? 'OCHIQ' : 'YOPIQ') + '</span>' : ''}
                                        </label>
                                        ${setting.description ? '<br><small class="form-text text-muted">' + setting.description + '</small>' : ''}
                                    </div>
                                </div>
                            </div>`;
                        }

                        if (setting.key === 'reports_access_code') {
                            return `
                            <div class="mb-3">
                                <div class="d-flex align-items-center justify-content-between p-3 border rounded bg-light user-select-none" style="cursor:pointer" onclick="toggleSecretField('reports_access_code')">
                                    <div class="d-flex align-items-center gap-2">
                                        <i class="fas fa-key text-warning"></i>
                                        <div>
                                            <strong>${setting.label || setting.key}</strong>
                                            <br><small class="text-danger fw-semibold">Bu yerga kirish mumkin emas</small>
                                        </div>
                                    </div>
                                    <button type="button" class="btn btn-sm btn-primary rounded-circle d-flex align-items-center justify-content-center" id="reports_access_code_toggle" style="width:32px;height:32px;flex:none" title="Ko'rsatish / Tahrirlash">
                                        <i class="fas fa-plus" id="reports_access_code_icon"></i>
                                    </button>
                                </div>
                                <div id="reports_access_code_field" class="mt-2 ps-1" style="display:none">
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="fas fa-lock"></i></span>
                                        <input type="password" class="form-control" id="reports_access_code" name="reports_access_code" value="${value || ''}" autocomplete="off" placeholder="Yangi kod">
                                        <button type="button" class="btn btn-outline-secondary" onclick="toggleSecretVisibility(this)" title="Ko'rsatish/Yashirish">
                                            <i class="fas fa-eye"></i>
                                        </button>
                                    </div>
                                    <small class="form-text text-danger fw-semibold">Bu yerga kirish mumkin emas</small>
                                </div>
                            </div>`;
                        }

                        if (setting.type === 'datetime') {
                            const dateValue = value ? new Date(value).toISOString().slice(0, 16) : '';
                            const displayDate = value ? new Date(value).toLocaleString('uz-UZ', {
                                timeZone: 'Asia/Tashkent',
                                dateStyle: 'short',
                                timeStyle: 'short'
                            }) : 'Hali yuborilmagan';
                            return `
                            <div class="mb-3">
                                <label for="${setting.key}" class="form-label"><strong>${setting.label || setting.key}</strong></label>
                                <input type="text" class="form-control" value="${displayDate}" readonly disabled>
                                <small class="form-text text-muted">${setting.description || ''}</small>
                            </div>`;
                        }

                        return `
                        <div class="mb-3">
                            <label for="${setting.key}" class="form-label"><strong>${setting.label || setting.key}</strong></label>
                            ${setting.type === 'textarea' ? `
                            <textarea class="form-control" id="${setting.key}" name="${setting.key}" rows="4">${value || ''}</textarea>
                            ` : setting.type === 'number' ? `
                            <input type="number" class="form-control" id="${setting.key}" name="${setting.key}" value="${value || 0}">
                            ` : `
                            <input type="text" class="form-control" id="${setting.key}" name="${setting.key}" value="${value || ''}">
                            `}
                            ${setting.description ? '<small class="form-text text-muted">' + setting.description + '</small>' : ''}
                        </div>`;
                    }).join('')}

                    <div class="d-flex justify-content-between">
                        <button type="reset" class="btn btn-secondary">
                            <i class="fas fa-redo me-2"></i>Qayta o'rnatish
                        </button>
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save me-2"></i>Saqlash
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card mb-3">
            <div class="card-header">
                <h5><i class="fas fa-info-circle me-2"></i>Ma'lumot</h5>
            </div>
            <div class="card-body">
                <p class="text-muted">Bu sahifada asosiy bot sozlamalarini o'zgartirishingiz mumkin.</p>
                <p class="text-muted"><i class="fas fa-lightbulb me-1"></i>Sozlamalar saqlanganidan keyin bot avtomatik ravishda yangi qiymatlarni oladi.</p>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h5><i class="fas fa-vial me-2"></i>Testlar</h5>
            </div>
            <div class="card-body">
                <form method="POST" action="/admin/settings/test-group-notification" class="mb-3">
                    <button type="submit" class="btn btn-info w-100">
                        <i class="fas fa-bullhorn me-2"></i>Guruh xabarini test qilish
                    </button>
                    <small class="form-text text-muted d-block mt-2">
                        Telegram guruhga test xabari yuboriladi
                    </small>
                </form>

                <form method="POST" action="/admin/settings/test-debt-reminders" onsubmit="return confirm('Barcha qarzdorlarga eslatma yuboriladi. Davom ettirasizmi?');">
                    <button type="submit" class="btn btn-warning w-100">
                        <i class="fas fa-paper-plane me-2"></i>Qarz eslatmalarini test qilish
                    </button>
                    <small class="form-text text-muted d-block mt-2">
                        Barcha qarzdor mijozlarga eslatma yuboriladi
                    </small>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
function toggleSecretField(key) {
    const field = document.getElementById(key + '_field');
    const icon = document.getElementById(key + '_icon');
    const isHidden = field.style.display === 'none';
    field.style.display = isHidden ? 'block' : 'none';
    icon.className = isHidden ? 'fas fa-minus' : 'fas fa-plus';
    if (isHidden) {
        document.getElementById(key).focus();
    }
}

function toggleSecretVisibility(btn) {
    const input = btn.closest('.input-group').querySelector('input');
    const icon = btn.querySelector('i');
    if (input.type === 'password') {
        input.type = 'text';
        icon.className = 'fas fa-eye-slash';
    } else {
        input.type = 'password';
        icon.className = 'fas fa-eye';
    }
}

function updateShopStatusStyle(checkbox) {
    const badge = document.getElementById('shop_status_badge');
    const container = checkbox.closest('.border.rounded');
    if (checkbox.checked) {
        badge.textContent = 'OCHIQ';
        badge.className = 'badge ms-2 bg-success';
        container.classList.remove('border-danger', 'bg-danger', 'bg-opacity-10');
        container.classList.add('border-success', 'bg-success', 'bg-opacity-10');
    } else {
        badge.textContent = 'YOPIQ';
        badge.className = 'badge ms-2 bg-danger';
        container.classList.remove('border-success', 'bg-success', 'bg-opacity-10');
        container.classList.add('border-danger', 'bg-danger', 'bg-opacity-10');
    }
}
</script>
`;
-%>
<%- include(layout, { body, title }) %>
